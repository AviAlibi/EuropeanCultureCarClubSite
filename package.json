{
	"name": "finance-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"app": "docker-compose up app -d",
		"lint": "next lint",
		"format": "prettier --check --ignore-path .gitignore .",
		"format:fix": "prettier --write --ignore-path .gitignore .",
		"db": "docker-compose up db -d",
		"db:generate": "npx prisma generate",
		"db:migrate-dev": "npx prisma migrate dev",
		"db:seed": "ts-node --compiler-options {\\\"module\\\":\\\"CommonJS\\\"} infra/prisma/seed.ts",
		"db:review": "ts-node --compiler-options {\\\"module\\\":\\\"CommonJS\\\"} infra/prisma/data-review.ts",
		"db:dev": "npm run db:migrate-dev && npm run db:generate && npm run db:seed",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"scrub": "docker system prune -a --volumes -f"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"dotenv": "^17.4.2",
		"lucide-react": "^1.21.0",
		"next": "16.0.3",
		"react": "19.2.0",
		"react-dom": "19.2.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^5.1.1",
		"@vitest/coverage-v8": "^4.1.9",
		"@vitest/ui": "^4.1.9",
		"eslint": "^9",
		"eslint-config-next": "16.0.3",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.4",
		"prisma": "^7.6.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vite": "^8.0.16",
		"vitest": "4.1.9"
	}
}
